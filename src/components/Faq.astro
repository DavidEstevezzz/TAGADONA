---
// ============================================================
//  Faq — Acordeón de preguntas frecuentes (visible, sin JS)
//  Usa <details>/<summary> nativos: accesible, indexable y
//  siempre presente en el HTML. Las mismas preguntas se pasan
//  a faqSchema() en la página para el JSON-LD FAQPage.
// ============================================================
const {
  faqs = [],
  title = "Preguntas frecuentes",
  eyebrow = "Resolvemos tus dudas",
} = Astro.props;
---

<section class="faq div-soft">
  <div class="wrap-narrow">
    <div class="faq-head reveal">
      <p class="eyebrow center">{eyebrow}</p>
      <h2 class="sec-title">{title}</h2>
    </div>
    <div class="faq-list reveal">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>
            <span class="faq-q head">{f.q}</span>
            <span class="faq-ico" aria-hidden="true"></span>
          </summary>
          <div class="faq-a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq{padding:var(--s-9) 0}
  .faq-head{text-align:center;margin-bottom:var(--s-7)}
  .faq-head .eyebrow{justify-content:center;margin-bottom:var(--s-4)}
  .faq-head .eyebrow::before{display:none}
  .faq-list{display:flex;flex-direction:column;gap:var(--s-3)}
  .faq-item{border:1px solid var(--line);border-radius:8px;
    background:rgba(255,255,255,.02);overflow:hidden;transition:border-color .3s}
  .faq-item[open]{border-color:var(--orange)}
  .faq-item summary{list-style:none;cursor:pointer;display:flex;align-items:center;
    justify-content:space-between;gap:var(--s-4);padding:var(--s-5) var(--s-6);
    transition:color .3s}
  .faq-item summary::-webkit-details-marker{display:none}
  .faq-item summary:hover{color:var(--orange-bright)}
  .faq-q{font-size:var(--fs-h3);font-weight:600;color:var(--text);line-height:1.3}
  .faq-item summary:hover .faq-q{color:var(--orange-bright)}
  /* Icono +/− construido con dos trazos */
  .faq-ico{position:relative;flex:none;width:18px;height:18px}
  .faq-ico::before,.faq-ico::after{content:"";position:absolute;background:var(--orange-bright);
    transition:transform .3s var(--ease)}
  .faq-ico::before{top:8px;left:0;width:18px;height:2px}
  .faq-ico::after{top:0;left:8px;width:2px;height:18px}
  .faq-item[open] .faq-ico::after{transform:rotate(90deg);opacity:0}
  .faq-a{padding:0 var(--s-6) var(--s-6)}
  .faq-a p{color:var(--text-dim);line-height:1.8;max-width:70ch}

  @media(max-width:560px){
    .faq-item summary{padding:var(--s-4) var(--s-5)}
    .faq-a{padding:0 var(--s-5) var(--s-5)}
  }
</style>
