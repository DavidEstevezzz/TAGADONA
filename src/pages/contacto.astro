---
import Base from '../layouts/Base.astro';
import { business, tel, mailto, whatsapp, direccionCompleta } from '../config/business.js';
const WHATSAPP = whatsapp;
const TELEFONO = tel;
const EMAIL = mailto;
const INSTAGRAM = business.instagram;
const TIKTOK = business.tiktok;
// Enlace "cómo llegar" a Google Maps a partir de la dirección real
const MAPS = business.maps;
const vias = [
  { lbl:"WhatsApp", val:"Respuesta rápida", href:WHATSAPP, tag:"WA", track:"whatsapp_general", source:"contacto" },
  { lbl:"Teléfono", val:business.telefonoVisible, href:TELEFONO, tag:"TEL", track:"telefono", source:"contacto" },
  { lbl:"Email", val:business.email, href:EMAIL, tag:"@", track:"email", source:"contacto" },
];
---
<Base
  title="Comprar o vender una moto en Granada | Tagadona Racing"
  desc="Contacta con Tagadona Racing para comprar o vender tu moto en Granada. Tasación, revisión, garantía y gestión del cambio de nombre."
>
  <section class="ct-hero">
    <div class="wrap">
      <p class="eyebrow reveal in">Estamos en Granada</p>
      <h1 class="ct-h1 display reveal in">Hablemos</h1>
      <p class="ct-lead reveal in">¿Te interesa una moto, quieres vender la tuya o tienes una duda? Escríbenos por el canal que prefieras. Sin compromiso.</p>
    </div>
  </section>
  <section class="ct-vias wrap">
    {vias.map((v,i)=>(
      <a class="via reveal" style={`transition-delay:${i*80}ms`} href={v.href}
         data-track={v.track} data-source={v.source}
         target={v.href.startsWith('http') ? '_blank' : undefined}
         rel={v.href.startsWith('http') ? 'noopener' : undefined}>
        <span class="via-tag cond">{v.tag}</span>
        <span class="via-lbl head">{v.lbl}</span>
        <span class="via-val">{v.val}</span>
        <span class="via-arr cond">→</span>
      </a>
    ))}
  </section>
  <section class="ct-info wrap reveal">
    <div>
      <h3 class="cond">Dónde estamos</h3>
      <p>
        <span itemprop="address">{direccionCompleta}</span>.
        Atendemos <strong>solo con cita previa</strong>, para que puedas ver y probar la moto con calma.
      </p>
      <a class="ct-maps" href={MAPS} target="_blank" rel="noopener" data-track="como_llegar" data-source="contacto">Cómo llegar →</a>
    </div>
    <div><h3 class="cond">Horario</h3><p>{business.horarioTexto}<br/>{business.horarioSabado}</p></div>
  </section>

  <section class="ct-redes wrap">
    <div class="ct-redes-head reveal">
      <p class="eyebrow center">Síguenos</p>
      <h2 class="sec-title">Estamos en redes</h2>
      <p class="ct-redes-lead">Cada semana subimos las nuevas incorporaciones y novedades del taller. Échales un ojo antes de que vuelen.</p>
    </div>
    <div class="ct-redes-grid">
      <a class="red-card red-ig reveal" href={INSTAGRAM} target="_blank" rel="noopener">
        <div class="red-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div class="red-body">
          <span class="red-net cond">Instagram</span>
          <span class="red-handle head">@tagadonaracing</span>
          <span class="red-desc">Fotos de cada moto, novedades y el día a día del taller.</span>
        </div>
        <span class="red-arr cond">Seguir →</span>
      </a>

      <a class="red-card red-tk reveal d1" href={TIKTOK} target="_blank" rel="noopener">
        <div class="red-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M16.5 3c.3 2.1 1.5 3.4 3.5 3.6v2.4c-1.2.1-2.4-.3-3.5-1v5.7c0 3.4-2.5 5.3-5.2 5.3-2.5 0-4.6-1.8-4.6-4.4 0-2.7 2.1-4.5 4.7-4.4.3 0 .5 0 .8.1v2.5c-.2-.1-.5-.1-.8-.1-1.2 0-2.2.9-2.2 2 0 1.2.9 2 2.1 2 1.3 0 2.2-.9 2.2-2.6V3h2.7z"/>
          </svg>
        </div>
        <div class="red-body">
          <span class="red-net cond">TikTok</span>
          <span class="red-handle head">@tagadona.racing</span>
          <span class="red-desc">Motos en movimiento, sonido real y lo que llega nuevo.</span>
        </div>
        <span class="red-arr cond">Seguir →</span>
      </a>
    </div>
  </section>
  <style>
    .ct-hero{padding:calc(74px + var(--s-9)) 0 var(--s-6);text-align:center}
    .ct-hero .eyebrow{margin-bottom:var(--s-5)}
    .ct-h1{font-size:clamp(56px,10vw,120px);line-height:.9;color:var(--orange-bright);margin-bottom:var(--s-4)}
    .ct-lead{color:var(--text-dim);font-size:var(--fs-lead);max-width:520px;margin:0 auto;line-height:1.6}
    .ct-vias{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--s-4);padding:var(--s-8) 0}
    .via{position:relative;background:var(--bg-card);border:1px solid var(--line);border-radius:6px;
      padding:var(--s-6);display:flex;flex-direction:column;gap:var(--s-2);
      transition:transform .4s var(--ease),border-color .4s}
    .via:hover{transform:translateY(-6px);border-color:var(--orange)}
    .via-tag{font-size:12px;font-weight:600;letter-spacing:.16em;color:var(--orange-bright);
      border:1px solid var(--line);width:fit-content;padding:4px 10px;border-radius:2px;margin-bottom:var(--s-3)}
    .via-lbl{font-size:var(--fs-h3);font-weight:600;color:var(--text)}
    .via-val{color:var(--text-dim);font-size:var(--fs-small)}
    .via-arr{position:absolute;top:var(--s-6);right:var(--s-6);color:var(--orange-bright);
      font-size:20px;transition:transform .3s var(--ease)}
    .via:hover .via-arr{transform:translate(4px,-4px)}
    .ct-info{display:grid;grid-template-columns:1fr 1fr;gap:var(--s-7);padding:var(--s-7) 0 0;
      border-top:1px solid var(--line-soft)}
    .ct-info h3{font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-faint);margin-bottom:var(--s-3)}
    .ct-info p{color:var(--text-dim);line-height:1.7}
    .ct-info p strong{color:var(--text);font-weight:600}
    .ct-maps{display:inline-flex;align-items:center;margin-top:var(--s-3);font-size:var(--fs-small);
      font-weight:600;letter-spacing:.06em;color:var(--orange-bright);transition:gap .3s var(--ease)}
    .ct-maps:hover{text-decoration:underline;text-underline-offset:3px}

    /* Tarjetas de redes */
    .ct-redes{padding:var(--s-9) 0 var(--s-8)}
    .ct-redes-head{text-align:center;margin-bottom:var(--s-7)}
    .ct-redes-head .eyebrow{justify-content:center;margin-bottom:var(--s-4)}
    .ct-redes-head .eyebrow::before{display:none}
    .ct-redes-lead{color:var(--text-dim);font-size:var(--fs-small);max-width:480px;
      margin:var(--s-4) auto 0;line-height:1.7}
    .ct-redes-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--s-5)}
    .red-card{position:relative;display:flex;flex-direction:column;gap:var(--s-4);
      padding:var(--s-7);border:1px solid var(--line);border-radius:10px;overflow:hidden;
      background:rgba(255,255,255,.02);transition:transform .4s var(--ease),border-color .4s}
    .red-card::before{content:"";position:absolute;inset:0;z-index:0;opacity:.14;
      transition:opacity .4s}
    .red-ig::before{background:radial-gradient(120% 120% at 0% 0%,#feda75,#fa7e1e 28%,#d62976 55%,#962fbf 78%,#4f5bd5)}
    .red-tk::before{background:radial-gradient(120% 120% at 0% 0%,#25F4EE,#000 45%,#FE2C55)}
    .red-card:hover{transform:translateY(-6px);border-color:var(--orange)}
    .red-card:hover::before{opacity:.24}
    .red-card > *{position:relative;z-index:1}
    .red-icon{width:56px;height:56px;border-radius:14px;background:rgba(255,255,255,.06);
      border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--text)}
    .red-icon svg{width:28px;height:28px}
    .red-net{font-size:12px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;
      color:var(--orange-bright);display:block;margin-bottom:4px}
    .red-handle{font-size:var(--fs-h3);font-weight:600;color:var(--text);display:block}
    .red-desc{color:var(--text-dim);font-size:var(--fs-small);line-height:1.6;display:block;margin-top:var(--s-2)}
    .red-arr{margin-top:auto;font-size:12px;font-weight:600;letter-spacing:.14em;
      text-transform:uppercase;color:var(--orange-bright);display:inline-flex;align-items:center;
      transition:gap .3s}
    .red-card:hover .red-arr{gap:var(--s-2)}

    @media(max-width:860px){.ct-vias{grid-template-columns:1fr}.ct-info{grid-template-columns:1fr;gap:var(--s-5)}
      .ct-redes-grid{grid-template-columns:1fr}}
  </style>
</Base>