    async function descargarPaqueteMoto(ventaId){
      const r=RENTABILIDAD.find(x=>x.venta.id===ventaId);
      if(!r){ alert('No se encontró la venta.'); return; }
      if(!window.JSZip){ alert('No se pudo cargar la librería ZIP. Recarga la página.'); return; }
      const zip=new JSZip();
      const f=r.venta;
      const baseNombre=archivoSeguro(`${f.fecha||''}_${motoTitulo(f)}_${f.moto_matricula||f.numero||''}`);
      zip.file(`venta_${archivoSeguro(f.numero||'factura')}.pdf`, await pdfBlob(f));
      for(const [i,g] of r.gastos.entries()){
        const nombre=`gasto_${String(i+1).padStart(2,'0')}_${archivoSeguro(g.proveedor_nombre||conceptoResumenG(g)||'gasto')}.pdf`;
        zip.file(nombre, await gastoPdfBlob(g));
      }
      const blob=await zip.generateAsync({type:'blob'});
      const url=URL.createObjectURL(blob); const a=document.createElement('a');
      a.href=url; a.download=`moto_${baseNombre}.zip`; a.click(); URL.revokeObjectURL(url);
    }

    // ============================================================
    //  PROVEEDORES  (datos de facturación reutilizables en gastos)
    // ============================================================
    let PROVEEDORES = [], VISTAP = [], PROV_CARGADOS = false, PROV_PROMISE = null;

    function esc(s){ return String(s??'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }

    function rellenarCatProv(){
      $('p_categoria').innerHTML = '<option value="">(sin categoría)</option>' +
        CATEGORIAS.map(c=>`<option value="${c}">${c}</option>`).join('');
    }
    rellenarCatProv();

    // Rellena el desplegable de proveedores del formulario de gasto.
    function rellenarSelectProveedores(){
      const sel=$('g_proveedor_id'); const actual=sel.value;
      const opts=['<option value="">— Manual / sin proveedor —</option>']
        .concat(PROVEEDORES.map(p=>`<option value="${p.id}">${esc(p.nombre)}${p.nif?' · '+esc(p.nif):''}</option>`));
      sel.innerHTML=opts.join('');
