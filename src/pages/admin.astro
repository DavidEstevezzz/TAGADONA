    function asegurarProveedores(){
      if(PROV_CARGADOS) return PROV_PROMISE || Promise.resolve();
      PROV_CARGADOS = true;
      PROV_PROMISE = cargarProveedores().finally(()=>{ PROV_PROMISE = null; });
      return PROV_PROMISE;
    }

    async function cargarProveedores(){
      $('listLoadingP').style.display='block'; $('tablaP').style.display='none'; $('listEmptyP').style.display='none';
      const { data, error } = await supabase.from('proveedores').select('*').order('nombre',{ascending:true});
      if(error){
        $('listLoadingP').textContent='No se pudieron cargar los proveedores. ¿Has creado la tabla «proveedores» en Supabase? ('+error.message+')';
        return;
      }
      PROVEEDORES = data||[]; $('listLoadingP').style.display='none';
      rellenarSelectProveedores();
      aplicarFiltrosP();
    }

    function aplicarProveedorAGasto(p){
      if(!p) return false;
      $('g_proveedor_id').value = p.id;
      $('g_proveedor_nombre').value = p.nombre || '';
      $('g_proveedor_nif').value = p.nif || '';
      if(p.forma_pago) $('g_forma_pago').value = p.forma_pago;
      if(p.categoria) $('g_categoria').value = p.categoria;
      return true;
    }

    function seleccionarProveedorDetectado(c){
      if(!PROVEEDORES.length) return false;
      const nifDetectado = normId(c.proveedor_nif || $('g_proveedor_nif').value);
      let proveedor = nifDetectado
        ? PROVEEDORES.find(p=>normId(p.nif) === nifDetectado)
        : null;
      if(!proveedor){
        const nombreDetectado = claveTexto(c.proveedor_nombre || $('g_proveedor_nombre').value);
        if(nombreDetectado.length >= 5){
          proveedor = PROVEEDORES.find(p=>claveTexto(p.nombre) === nombreDetectado);
        }
      }
      return proveedor ? aplicarProveedorAGasto(proveedor) : false;
    }

    function aplicarFiltrosP(){
      const q=$('buscarP').value.toLowerCase().trim();
      VISTAP = PROVEEDORES.filter(p=> !q || `${p.nombre||''} ${p.nif||''}`.toLowerCase().includes(q));
      pintarTablaP();
    }
    $('buscarP').addEventListener('input',aplicarFiltrosP);

    function pintarTablaP(){
      if(!VISTAP.length){ $('tablaP').style.display='none'; $('listEmptyP').style.display='block'; return; }
      $('listEmptyP').style.display='none'; const tb=$('tbodyP'); tb.innerHTML='';
      VISTAP.forEach(p=>{
        const tr=document.createElement('tr');
        tr.innerHTML=`<td>${esc(p.nombre)||'—'}</td><td>${esc(p.nif)||'—'}</td>
          <td>${esc(p.email)||'—'}</td><td>${esc(p.telefono)||'—'}</td>
          <td>${p.categoria?`<span class="adm-tag iva">${esc(p.categoria)}</span>`:''}</td>
          <td><div class="adm-row-btns">
            <button class="adm-ico" data-editp="${p.id}" title="Editar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
            <button class="adm-ico del" data-delp="${p.id}" title="Borrar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
          </div></td>`;
        tb.appendChild(tr);
      });
      $('tablaP').style.display='table';
      const find=(id)=>VISTAP.find(x=>x.id===id);
      tb.querySelectorAll('[data-editp]').forEach(b=>b.onclick=()=>abrirFormProv(find(b.dataset.editp)));
      tb.querySelectorAll('[data-delp]').forEach(b=>b.onclick=()=>borrarProv(find(b.dataset.delp)));
    }

    function abrirFormProv(p){
      $('formViewP').style.display='block'; $('formErrorP').textContent='';
      $('formTitleP').textContent = p && p.id ? 'Editar proveedor' : 'Nuevo proveedor';
      $('p_id').value=p?.id||'';
      $('p_nombre').value=p?.nombre||'';
      $('p_nif').value=p?.nif||'';
      $('p_direccion').value=p?.direccion||'';
      $('p_email').value=p?.email||'';
      $('p_telefono').value=p?.telefono||'';
      $('p_forma_pago').value=p?.forma_pago||'';
      $('p_categoria').value=p?.categoria||'';
      $('p_notas').value=p?.notas||'';
      window.scrollTo({top:0,behavior:'smooth'});
    }
    $('btnNuevoProv').addEventListener('click',()=>abrirFormProv());
    $('btnCancelarProv').addEventListener('click',()=>{ $('formViewP').style.display='none'; });
    $('p_nombre').addEventListener('blur',e=>{ e.target.value=normIniciales(e.target.value); });
    $('p_nif').addEventListener('blur',e=>{ e.target.value=normId(e.target.value); });

    $('btnGuardarProv').addEventListener('click', async ()=>{
      $('formErrorP').textContent='';
      const p={
        nombre:normIniciales($('p_nombre').value),
        nif:normId($('p_nif').value),
        direccion:$('p_direccion').value.trim(),
        email:$('p_email').value.trim(),
        telefono:$('p_telefono').value.trim(),
        forma_pago:$('p_forma_pago').value.trim(),
        categoria:$('p_categoria').value,
        notas:$('p_notas').value.trim(),
      };
      if(!p.nombre){ $('formErrorP').textContent='El nombre del proveedor es obligatorio.'; return; }
      const id=$('p_id').value;
      const btn=$('btnGuardarProv'); const txt=btn.textContent; btn.disabled=true; btn.textContent='Guardando…';
      try{
        let error;
        if(id){ ({error}=await supabase.from('proveedores').update(p).eq('id',id)); }
        else { ({error}=await supabase.from('proveedores').insert(p)); }
        if(error) throw error;
        $('formViewP').style.display='none'; cargarProveedores();
      }catch(err){ $('formErrorP').textContent='Error al guardar: '+(err.message||err); }
      finally{ btn.disabled=false; btn.textContent=txt; }
    });
    async function borrarProv(p){
      if(!confirm('¿Borrar este proveedor? Los gastos ya creados conservan sus datos.')) return;
      const { error } = await supabase.from('proveedores').delete().eq('id',p.id);
      if(error){ alert('No se pudo borrar: '+error.message); return; }
      cargarProveedores();
    }

    checkSession();
  </script>
</Base>
