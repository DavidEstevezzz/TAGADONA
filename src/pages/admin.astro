    // ============================================================
    //  GASTOS  (compras / facturas recibidas, con adjunto y OCR)
    // ============================================================
    const BUCKET = 'gastos-adjuntos';
    const CATEGORIAS = ['Repuestos / recambios','Compra de vehículo','Transporte / logística',
      'Suministros','Herramientas','Servicios profesionales','Impuestos / tasas','Publicidad','Otros'];
    let GASTOS = [], VISTAG = [], GASTOS_CARGADOS = false, gPendingFile = null;

    function rellenarSelectVentasG(){
      const sel=$('g_venta_id');
      if(!sel) return;
      const actual=sel.value;
      sel.innerHTML = '<option value="">— Sin asociar a una venta —</option>' +
        TODAS.map(f=>`<option value="${f.id}">${esc(ventaLabel(f))}</option>`).join('');
      sel.value = actual;
    }

    function rellenarCategorias(){
      const opt = CATEGORIAS.map(c=>`<option value="${c}">${c}</option>`).join('');
      $('g_categoria').innerHTML = opt;
      $('filtroCatG').innerHTML = '<option value="">Todas las categorías</option>'+opt;
    }
    rellenarCategorias();

    // ----- Pestañas -----
    const VIEWS = { ventas:['viewVentas','tabVentas'], gastos:['viewGastos','tabGastos'], rentabilidad:['viewRentabilidad','tabRentabilidad'], proveedores:['viewProveedores','tabProveedores'] };
    function activarTab(tab){
      Object.entries(VIEWS).forEach(([k,[view,btn]])=>{
        $(view).hidden = k!==tab;
        $(btn).classList.toggle('is-active', k===tab);
      });
      // Los proveedores se necesitan tanto en su pestaña como en el selector de gastos.
      if(tab==='gastos'||tab==='proveedores') asegurarProveedores();
      if((tab==='gastos'||tab==='rentabilidad') && !GASTOS_CARGADOS){ GASTOS_CARGADOS=true; cargarGastos(); }
      if(tab==='rentabilidad') pintarRentabilidad();
    }
    $('tabVentas').addEventListener('click',()=>activarTab('ventas'));
    $('tabGastos').addEventListener('click',()=>activarTab('gastos'));
    $('tabRentabilidad').addEventListener('click',()=>activarTab('rentabilidad'));
    $('tabProveedores').addEventListener('click',()=>activarTab('proveedores'));

    // ----- Cargar y filtrar -----
    async function cargarGastos(){
      $('listLoadingG').style.display='block'; $('tablaG').style.display='none'; $('listEmptyG').style.display='none';
      const { data, error } = await supabase.from('gastos').select('*').order('fecha',{ascending:false});
      if(error){
        $('listLoadingG').textContent = 'No se pudieron cargar los gastos. ¿Has creado la tabla «gastos» en Supabase? ('+error.message+')';
        return;
      }
      GASTOS = data||[]; $('listLoadingG').style.display='none';
      aplicarFiltrosG();
      pintarRentabilidad();
    }
    function aplicarFiltrosG(){
      const q=$('buscarG').value.toLowerCase().trim();
      const cat=$('filtroCatG').value, per=$('filtroPeriodoG').value;
      VISTAG = GASTOS.filter(g=>{
        if(cat && g.categoria!==cat) return false;
        if(!enPeriodo(g,per)) return false;
        if(q && !(`${g.proveedor_nombre||''} ${conceptoResumenG(g)}`.toLowerCase().includes(q))) return false;
        return true;
      });
      pintarResumenG(); pintarTablaG();
    }
    ['buscarG','filtroCatG','filtroPeriodoG'].forEach(id=>$(id).addEventListener('input',aplicarFiltrosG));

    function pintarResumenG(){
      const total=VISTAG.reduce((s,g)=>s+Number(g.total||0),0);
      const base=VISTAG.reduce((s,g)=>s+Number(g.base||0),0);
      const iva=VISTAG.reduce((s,g)=>s+Number(g.iva_importe||0),0);
      $('resumenG').innerHTML=`
        <div class="adm-stat"><div class="adm-stat-n">${VISTAG.length}</div><div class="adm-stat-l">Gastos</div></div>
        <div class="adm-stat"><div class="adm-stat-n">${eur(total)}</div><div class="adm-stat-l">Total gastado</div></div>
        <div class="adm-stat"><div class="adm-stat-n">${eur(base)}</div><div class="adm-stat-l">Base imponible</div></div>
        <div class="adm-stat"><div class="adm-stat-n">${eur(iva)}</div><div class="adm-stat-l">IVA soportado</div></div>`;
    }
    function pintarTablaG(){
      if(!VISTAG.length){ $('tablaG').style.display='none'; $('listEmptyG').style.display='block'; return; }
      $('listEmptyG').style.display='none'; const tb=$('tbodyG'); tb.innerHTML='';
      VISTAG.forEach(g=>{
        const tr=document.createElement('tr');
        const adj = g.archivo_path
          ? `<button class="adm-ico" data-adj="${g.id}" title="Ver adjunto"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg></button>`
          : '—';
        tr.innerHTML=`<td>${g.fecha?g.fecha.split('-').reverse().join('/'):''}</td>
          <td>${esc(g.proveedor_nombre)||'—'}</td>
          <td>${esc(conceptoResumenG(g))||'—'}</td>
          <td>${g.categoria?`<span class="adm-tag iva">${esc(g.categoria)}</span>`:''}</td>
          <td>${eur(g.base)}</td><td>${eur(g.iva_importe)}</td><td>${eur(g.total)}</td>
          <td style="text-align:center">${adj}</td>
          <td><div class="adm-row-btns">
            <button class="adm-ico" data-pdfg="${g.id}" title="Descargar PDF"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg></button>
            <button class="adm-ico" data-editg="${g.id}" title="Editar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
            <button class="adm-ico del" data-delg="${g.id}" title="Borrar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
          </div></td>`;
        tb.appendChild(tr);
      });
      $('tablaG').style.display='table';
      const find=(id)=>VISTAG.find(x=>x.id===id);
      tb.querySelectorAll('[data-adj]').forEach(b=>b.onclick=()=>verAdjunto(find(b.dataset.adj)));
      tb.querySelectorAll('[data-pdfg]').forEach(b=>b.onclick=()=>descargarGastoPDF(find(b.dataset.pdfg)));
      tb.querySelectorAll('[data-editg]').forEach(b=>b.onclick=()=>abrirFormGasto(find(b.dataset.editg)));
      tb.querySelectorAll('[data-delg]').forEach(b=>b.onclick=()=>borrarGasto(find(b.dataset.delg)));
    }

    // ----- Formulario -----
    function lineasGasto(g){
      const raw = Array.isArray(g?.lineas) ? g.lineas : [];
      const lineas = raw.map(l=>({
        concepto:String(l?.concepto||'').trim(),
        base:Number(l?.base ?? l?.importe ?? 0) || 0,
      })).filter(l=>l.concepto || l.base);
      if(lineas.length) return lineas;
      if(g?.concepto || Number(g?.base||0)){
        return [{ concepto:g?.concepto||'', base:Number(g?.base||0) || 0 }];
      }
      return [];
    }
    function conceptoResumenLineas(lineas){
      const nombres = lineas.map(l=>l.concepto).filter(Boolean);
      if(!nombres.length) return '';
      return nombres.length <= 2 ? nombres.join(', ') : `${nombres.slice(0,2).join(', ')} +${nombres.length-2}`;
    }
    function conceptoResumenG(g){ return conceptoResumenLineas(lineasGasto(g)) || g?.concepto || ''; }
    function renderLineasGasto(lineas=[{}]){
      const rows = lineas.length ? lineas : [{}];
      $('g_lineas').innerHTML = rows.map((l,i)=>`
        <div class="adm-line-row" data-linea-g>
          <input type="text" class="adm-input g-linea-concepto" placeholder="Concepto ${i+1}" value="${esc(l.concepto||'')}" />
          <input type="number" step="0.01" class="adm-input g-linea-base" placeholder="Base €" value="${l.base ?? ''}" />
          <button type="button" class="adm-ico del g-linea-del" title="Quitar línea"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></button>
        </div>`).join('');
      recalcTotalG();
    }
    function leerLineasGasto(){
      return [...document.querySelectorAll('[data-linea-g]')].map(row=>({
        concepto:row.querySelector('.g-linea-concepto').value.trim(),
        base:+(parseFloat(row.querySelector('.g-linea-base').value)||0).toFixed(2),
      })).filter(l=>l.concepto || l.base);
    }
    function abrirFormGasto(g){
      $('formViewG').style.display='block'; $('formErrorG').textContent='';
      $('ocrBox').hidden=true; $('ocrBarFill').style.width='0%'; gPendingFile=null;
      $('formTitleG').textContent = g && g.id ? 'Editar gasto' : 'Nuevo gasto';
      $('g_id').value = g?.id || '';
      rellenarSelectVentasG();
      $('g_venta_id').value = g?.venta_id || '';
      $('g_proveedor_id').value = g?.proveedor_id || '';
      $('g_fecha').value = g?.fecha || new Date().toISOString().slice(0,10);
      $('g_categoria').value = g?.categoria || CATEGORIAS[0];
      $('g_proveedor_nombre').value = g?.proveedor_nombre || '';
      $('g_proveedor_nif').value = g?.proveedor_nif || '';
      $('g_iva_pct').value = g?.iva_pct ?? 21;
      renderLineasGasto(lineasGasto(g));
      $('g_forma_pago').value = g?.forma_pago ?? 'Transferencia bancaria';
      $('g_notas').value = g?.notas || '';
      $('g_file').value='';
      $('gFileHint').className='adm-hint';
      $('gFileHint').textContent = g?.archivo_nombre ? ('Adjunto actual: '+g.archivo_nombre) : '';
      window.scrollTo({top:0,behavior:'smooth'});
    }
    $('btnNuevoGasto').addEventListener('click',()=>abrirFormGasto());
    $('btnCancelarGasto').addEventListener('click',()=>{ $('formViewG').style.display='none'; });

    function recalcTotalG(){
      const base=leerLineasGasto().reduce((s,l)=>s+Number(l.base||0),0), iva=parseFloat($('g_iva_pct').value)||0;
      $('g_base').value=base.toFixed(2);
      $('g_total').value=(base*(1+iva/100)).toFixed(2);
    }
    $('g_iva_pct').addEventListener('input',recalcTotalG);
    $('btnAddLineaG').addEventListener('click',()=>renderLineasGasto(leerLineasGasto().concat({concepto:'',base:''})));
    $('g_lineas').addEventListener('input',recalcTotalG);
    $('g_lineas').addEventListener('click',e=>{
      const btn=e.target.closest('.g-linea-del');
      if(!btn) return;
      const rows=leerLineasGasto();
      const idx=[...document.querySelectorAll('[data-linea-g]')].indexOf(btn.closest('[data-linea-g]'));
      rows.splice(idx,1);
      renderLineasGasto(rows.length ? rows : [{}]);
    });
    $('g_proveedor_nombre').addEventListener('blur',e=>{ e.target.value=normIniciales(e.target.value); });
    $('g_proveedor_nif').addEventListener('blur',e=>{ e.target.value=normId(e.target.value); });

    // Al elegir un proveedor del desplegable se autorrellenan sus datos.
    $('g_proveedor_id').addEventListener('change', ()=>{
      const p = PROVEEDORES.find(x=>x.id===$('g_proveedor_id').value);
      if(!p) return; // opción "manual"
      aplicarProveedorAGasto(p);
    });
    // Atajo para crear un proveedor sin salir manualmente.
    $('btnProvRapido').addEventListener('click', ()=>{ activarTab('proveedores'); abrirFormProv(); });

    // ----- Subida + lectura automática -----
    function resumirErrorIA(err){
      const raw = String(err?.message || err || 'error desconocido');
      if(/429|quota|RESOURCE_EXHAUSTED/i.test(raw)) return 'cuota de Gemini agotada';
      if(/GEMINI_API_KEY/i.test(raw)) return 'falta la clave GEMINI_API_KEY';
      if(/404|not found|FunctionsHttpError/i.test(raw)) return 'función de Supabase no desplegada';
      return raw.replace(/\s+/g,' ').slice(0,140);
    }

    async function manejarArchivo(file){
      if(!file) return;
      gPendingFile=file;
      $('gFileHint').className='adm-hint';
      $('gFileHint').textContent='Archivo seleccionado: '+file.name;
      const box=$('ocrBox'), fill=$('ocrBarFill'), msg=$('ocrMsg');
      box.hidden=false; fill.style.width='0%'; msg.textContent='Preparando lectura…';
      const prog=(p)=>{ if(p && p.pct!=null) fill.style.width=p.pct+'%'; if(p && p.msg) msg.textContent=p.msg; };
      const esImagen=(file.type||'').startsWith('image/');
      try{
        let campos;
        // Tanto imágenes como PDFs se leen con IA (Gemini) por precisión:
        // Gemini acepta el PDF directamente (todas sus páginas, con o sin capa
        // de texto). Si la función no está desplegada, falla o se agota la
        // cuota, se recurre a la lectura local del navegador como red de
        // seguridad: OCR para imágenes, texto/OCR de pdf.js para PDFs.
        let metodoLectura = 'ia';
        let motivoFallback = '';
        try{
          campos = await extraerConIA(file, prog);
        }catch(e){
          motivoFallback = resumirErrorIA(e);
          metodoLectura = esImagen ? 'ocr' : 'pdf';
          prog({msg:`IA no disponible (${motivoFallback}), usando lectura local…`});
          await cargarLibsOCR();
          campos = parsearCamposFactura(await extraerTextoFactura(file, prog));
        }
        fill.style.width='100%';
        await asegurarProveedores();
        const n = aplicarCamposDetectados(campos);
        if(n){
          if(metodoLectura === 'ia'){
            msg.textContent = `✓ ${n} campo(s) detectado(s) con IA. Revísalos antes de guardar.`;
          }else{
            const comoLocal = metodoLectura === 'ocr' ? 'OCR local' : 'lectura local del PDF';
            msg.textContent = `✓ ${n} campo(s) detectado(s) con ${comoLocal}. IA no disponible: ${motivoFallback}. Revísalos antes de guardar.`;
          }
        }else{
          msg.textContent = motivoFallback
            ? `IA no disponible: ${motivoFallback}. Lectura local sin campos claros; rellénalos a mano.`
            : 'No se detectaron campos automáticamente. Rellénalos a mano.';
        }
      }catch(err){
        msg.textContent='No se pudo leer el archivo automáticamente. Rellena los campos a mano.';
      }
    }
    function aplicarCamposDetectados(c){
      let n=0;
      if(c.fecha){ $('g_fecha').value=c.fecha; n++; }
      if(c.proveedor_nombre){ $('g_proveedor_nombre').value=normIniciales(c.proveedor_nombre); n++; }
      if(c.proveedor_nif){ $('g_proveedor_nif').value=normId(c.proveedor_nif); n++; }
      if(c.iva_pct!=null){ $('g_iva_pct').value=c.iva_pct; n++; }
      const iva=parseFloat($('g_iva_pct').value)||0;
      const detectadas = Array.isArray(c.lineas) ? c.lineas.map(l=>({
        concepto:String(l?.concepto||'').trim(),
        base:Number(l?.base ?? l?.importe ?? 0) || 0,
      })).filter(l=>l.concepto || l.base) : [];
      if(detectadas.length){
        renderLineasGasto(detectadas); n += detectadas.length;
      }else if(c.base!=null || c.total!=null){
        const base = c.base!=null ? Number(c.base) : Number(c.total)/(1+iva/100);
        renderLineasGasto([{concepto:'',base:+base.toFixed(2)}]); n++;
      }else{
        recalcTotalG();
      }
      if(seleccionarProveedorDetectado(c)) n++;
      return n;
    }
    $('g_file').addEventListener('change',e=>manejarArchivo(e.target.files[0]));
    $('gFileTop').addEventListener('change',e=>{
      const file=e.target.files[0]; e.target.value='';
      abrirFormGasto(); manejarArchivo(file);
    });

    // ----- Adjuntos en Supabase Storage -----
    async function subirAdjunto(file){
      const ext=(file.name.split('.').pop()||'bin').toLowerCase().replace(/[^a-z0-9]/g,'')||'bin';
      const path=`${new Date().getFullYear()}/${Date.now()}_${Math.random().toString(36).slice(2,8)}.${ext}`;
      const { error } = await supabase.storage.from(BUCKET).upload(path,file,{
        contentType:file.type||'application/octet-stream', upsert:false });
      if(error) throw error;
      return { path, nombre:file.name };
    }
    async function verAdjunto(g){
      if(!g?.archivo_path) return;
      const { data, error } = await supabase.storage.from(BUCKET).createSignedUrl(g.archivo_path,3600);
      if(error){ alert('No se pudo abrir el adjunto: '+error.message); return; }
      window.open(data.signedUrl,'_blank');
    }

    // ----- Guardar / borrar -----
    $('btnGuardarGasto').addEventListener('click', async ()=>{
      $('formErrorG').textContent='';
      const lineas=leerLineasGasto();
      const base=+lineas.reduce((s,l)=>s+Number(l.base||0),0).toFixed(2);
      const ivaPct=parseFloat($('g_iva_pct').value)||0;
      const total=+(base*(1+ivaPct/100)).toFixed(2);
      const ivaImporte=Math.max(0,+(total-base).toFixed(2));
      const concepto=conceptoResumenLineas(lineas);
      const g={
        fecha:$('g_fecha').value||null,
        categoria:$('g_categoria').value,
        venta_id:$('g_venta_id').value||null,
        proveedor_id:$('g_proveedor_id').value||null,
        proveedor_nombre:normIniciales($('g_proveedor_nombre').value),
        proveedor_nif:normId($('g_proveedor_nif').value),
        concepto,
        lineas,
        base, iva_pct:ivaPct, iva_importe:ivaImporte, total,
        forma_pago:$('g_forma_pago').value.trim(),
        notas:$('g_notas').value.trim(),
      };
      if(!g.proveedor_nombre && !g.concepto){ $('formErrorG').textContent='Indica al menos el proveedor o un concepto.'; return; }
      if(!lineas.length){ $('formErrorG').textContent='Añade al menos una línea de concepto con importe.'; return; }
      if(lineas.some(l=>!l.concepto || Number(l.base||0)<=0)){ $('formErrorG').textContent='Cada línea debe tener concepto e importe mayor que cero.'; return; }
      const id=$('g_id').value;
      const btn=$('btnGuardarGasto'); const txt=btn.textContent; btn.disabled=true; btn.textContent='Guardando…';
      try{
        if(gPendingFile){
          const adj=await subirAdjunto(gPendingFile);
          g.archivo_path=adj.path; g.archivo_nombre=adj.nombre;
        }
        let error;
        if(id){ ({error}=await supabase.from('gastos').update(g).eq('id',id)); }
        else { ({error}=await supabase.from('gastos').insert(g)); }
        if(error) throw error;
        $('formViewG').style.display='none'; gPendingFile=null; cargarGastos();
      }catch(err){
        $('formErrorG').textContent='Error al guardar: '+(err.message||err);
      }finally{ btn.disabled=false; btn.textContent=txt; }
    });
    async function borrarGasto(g){
      if(!confirm('¿Borrar este gasto?')) return;
      if(g.archivo_path){ await supabase.storage.from(BUCKET).remove([g.archivo_path]); }
      await supabase.from('gastos').delete().eq('id',g.id);
      cargarGastos();
    }

