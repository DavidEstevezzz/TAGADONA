---
import Base from '../layouts/Base.astro';
---
<Base title="Administración — Tagadona Racing">
  <section class="adm">
    <!-- LOGIN -->
    <div class="adm-login" id="loginView" style="display:none">
      <div class="adm-card">
        <h1 class="head">Acceso equipo</h1>
        <p class="adm-sub">Introduce tus credenciales</p>
        <input type="email" id="email" placeholder="Email" class="adm-input" />
        <input type="password" id="pass" placeholder="Contraseña" class="adm-input" />
        <button id="btnLogin" class="btn btn-primary adm-btn">Entrar</button>
        <p class="adm-error" id="loginError"></p>
      </div>
    </div>

    <!-- PANEL -->
    <div class="adm-panel" id="panelView" style="display:none">
      <div class="wrap">
        <div class="adm-top">
          <div>
            <p class="eyebrow">Facturación</p>
            <h1 class="head">Panel de facturas</h1>
          </div>
          <button id="btnLogout" class="btn btn-ghost">Cerrar sesión</button>
        </div>

        <!-- PESTAÑAS VENTAS / GASTOS / PROVEEDORES -->
        <div class="adm-tabs" role="tablist">
          <button class="adm-tab is-active" id="tabVentas" role="tab">Ventas</button>
          <button class="adm-tab" id="tabGastos" role="tab">Gastos</button>
          <button class="adm-tab" id="tabRentabilidad" role="tab">Rentabilidad</button>
          <button class="adm-tab" id="tabProveedores" role="tab">Proveedores</button>
        </div>

        <!-- ===================== VENTAS ===================== -->
        <div id="viewVentas">
        <!-- RESUMEN -->
        <div class="adm-resumen" id="resumen"></div>

        <!-- ACCIONES + FILTROS -->
        <div class="adm-bar">
          <button id="btnNueva" class="btn btn-primary">+ Nueva factura</button>
          <input type="text" id="buscar" class="adm-input adm-search" placeholder="Buscar cliente o nº…" />
          <select id="filtroTipo" class="adm-input adm-mini-sel">
            <option value="">Todos los tipos</option>
            <option value="REBU">REBU</option>
            <option value="IVA">IVA</option>
          </select>
          <select id="filtroPeriodo" class="adm-input adm-mini-sel">
            <option value="">Todo el tiempo</option>
            <option value="mes">Este mes</option>
            <option value="trim">Este trimestre</option>
            <option value="anio">Este año</option>
          </select>
        </div>

        <!-- EXPORTACIÓN POR LOTES -->
        <div class="adm-export">
          <span class="adm-export-lbl">Exportar lo filtrado:</span>
          <button id="btnExcel" class="adm-mini">Excel (.xlsx)</button>
          <button id="btnZip" class="adm-mini">ZIP de PDFs</button>
        </div>

        <!-- FORMULARIO -->
        <div class="adm-form" id="formView" style="display:none">
          <h2 class="head" id="formTitle">Nueva factura</h2>
          <div class="adm-form-cols">
            <div class="adm-form-fields">
              <input type="hidden" id="f_id" />
              <div class="adm-grid">
                <label>Tipo
                  <select id="f_tipo" class="adm-input">
                    <option value="REBU">REBU (particular)</option>
                    <option value="IVA">Con IVA 21% (empresa)</option>
                  </select>
                </label>
                <label>Fecha<input type="date" id="f_fecha" class="adm-input" /></label>
                <label>Cliente — Nombre<input type="text" id="f_cliente_nombre" class="adm-input" /></label>
                <label>Cliente — NIF/NIE<input type="text" id="f_cliente_nif" class="adm-input" /><span class="adm-hint" id="nifHint"></span></label>
                <label class="adm-full">Cliente — Dirección<input type="text" id="f_cliente_direccion" class="adm-input" /></label>
                <label>Moto — Marca<input type="text" id="f_moto_marca" class="adm-input" /></label>
                <label>Moto — Modelo<input type="text" id="f_moto_modelo" class="adm-input" /></label>
                <label>Moto — Matrícula<input type="text" id="f_moto_matricula" class="adm-input" /></label>
                <label>Moto — Bastidor<input type="text" id="f_moto_bastidor" class="adm-input" /></label>
                <label>Importe (€)<input type="number" step="0.01" id="f_importe" class="adm-input" /></label>
                <label>Cambio de nombre<input type="text" id="f_cambio_nombre" class="adm-input" value="INCLUIDO" /></label>
                <label class="adm-full">Garantía<input type="text" id="f_garantia" class="adm-input" value="12 meses de motor (sin incluir piezas de desgaste)" /></label>
                <label>Forma de pago<input type="text" id="f_forma_pago" class="adm-input" value="Transferencia bancaria" /></label>
              </div>
              <div class="adm-form-btns">
                <button id="btnGuardar" class="btn btn-primary">Guardar</button>
                <button id="btnCancelar" class="btn btn-ghost">Cancelar</button>
              </div>
              <p class="adm-error" id="formError"></p>
            </div>
            <!-- VISTA PREVIA EN VIVO -->
            <div class="adm-preview">
              <span class="adm-preview-lbl">Vista previa</span>
              <div class="prev-doc" id="prevDoc"></div>
            </div>
          </div>
        </div>

        <!-- LISTADO -->
        <div class="adm-list">
          <p class="adm-loading" id="listLoading">Cargando…</p>
          <table class="adm-table" id="tabla" style="display:none">
            <thead><tr><th>Nº</th><th>Fecha</th><th>Tipo</th><th>Cliente</th><th>Moto</th><th>Total</th><th></th></tr></thead>
            <tbody id="tbody"></tbody>
          </table>
          <p class="adm-empty" id="listEmpty" style="display:none">No hay facturas que coincidan.</p>
        </div>
        </div><!-- /viewVentas -->

        <!-- ===================== GASTOS ===================== -->
        <div id="viewGastos" hidden>
          <!-- RESUMEN GASTOS -->
          <div class="adm-resumen" id="resumenG"></div>

          <!-- ACCIONES + FILTROS -->
          <div class="adm-bar">
            <button id="btnNuevoGasto" class="btn btn-primary">+ Nuevo gasto</button>
            <label class="btn btn-ghost adm-upload">⬆ Subir factura
              <input type="file" id="gFileTop" accept="application/pdf,image/*" hidden />
            </label>
            <input type="text" id="buscarG" class="adm-input adm-search" placeholder="Buscar proveedor o concepto…" />
            <select id="filtroCatG" class="adm-input adm-mini-sel">
              <option value="">Todas las categorías</option>
            </select>
            <select id="filtroPeriodoG" class="adm-input adm-mini-sel">
              <option value="">Todo el tiempo</option>
              <option value="mes">Este mes</option>
              <option value="trim">Este trimestre</option>
              <option value="anio">Este año</option>
            </select>
          </div>

          <div class="adm-export">
            <span class="adm-export-lbl">Exportar lo filtrado:</span>
            <button id="btnExcelG" class="adm-mini">Excel (.xlsx)</button>
          </div>

          <!-- FORMULARIO GASTO -->
          <div class="adm-form" id="formViewG" style="display:none">
            <h2 class="head" id="formTitleG">Nuevo gasto</h2>

            <!-- Estado de la lectura automática -->
            <div class="adm-ocr" id="ocrBox" hidden>
              <div class="adm-ocr-bar"><span id="ocrBarFill"></span></div>
              <p class="adm-ocr-msg" id="ocrMsg"></p>
            </div>

            <div class="adm-grid">
              <input type="hidden" id="g_id" />
              <label class="adm-full">Venta asociada
                <select id="g_venta_id" class="adm-input">
                  <option value="">— Sin asociar a una venta —</option>
                </select>
              </label>
              <label class="adm-full">Proveedor
                <div class="adm-prov-row">
                  <select id="g_proveedor_id" class="adm-input">
                    <option value="">— Manual / sin proveedor —</option>
                  </select>
                  <button type="button" id="btnProvRapido" class="adm-mini">+ Nuevo</button>
                </div>
              </label>
              <label>Fecha<input type="date" id="g_fecha" class="adm-input" /></label>
              <label>Categoría<select id="g_categoria" class="adm-input"></select></label>
              <label>Proveedor — Nombre<input type="text" id="g_proveedor_nombre" class="adm-input" /></label>
              <label>Proveedor — NIF/CIF<input type="text" id="g_proveedor_nif" class="adm-input" /></label>
              <div class="adm-full adm-lines-box">
                <div class="adm-lines-head">
                  <span>Conceptos de la factura</span>
                  <button type="button" id="btnAddLineaG" class="adm-mini">+ Línea</button>
                </div>
                <div class="adm-lines" id="g_lineas"></div>
              </div>
              <label>Base imponible total (€)<input type="number" step="0.01" id="g_base" class="adm-input" readonly /></label>
              <label>IVA (%)<input type="number" step="0.01" id="g_iva_pct" class="adm-input" value="21" /></label>
              <label>Total factura (€)<input type="number" step="0.01" id="g_total" class="adm-input" readonly /></label>
              <label>Forma de pago<input type="text" id="g_forma_pago" class="adm-input" value="Transferencia bancaria" /></label>
              <label class="adm-full">Adjunto (PDF o imagen)
                <input type="file" id="g_file" accept="application/pdf,image/*" class="adm-input adm-file" />
                <span class="adm-hint" id="gFileHint"></span>
              </label>
              <label class="adm-full">Notas<input type="text" id="g_notas" class="adm-input" /></label>
            </div>
            <div class="adm-form-btns">
              <button id="btnGuardarGasto" class="btn btn-primary">Guardar</button>
              <button id="btnCancelarGasto" class="btn btn-ghost">Cancelar</button>
            </div>
            <p class="adm-error" id="formErrorG"></p>
          </div>

          <!-- LISTADO GASTOS -->
          <div class="adm-list">
            <p class="adm-loading" id="listLoadingG">Cargando…</p>
            <table class="adm-table" id="tablaG" style="display:none">
              <thead><tr><th>Fecha</th><th>Proveedor</th><th>Concepto</th><th>Categoría</th><th>Base</th><th>IVA</th><th>Total</th><th>Adj.</th><th></th></tr></thead>
              <tbody id="tbodyG"></tbody>
            </table>
            <p class="adm-empty" id="listEmptyG" style="display:none">No hay gastos que coincidan.</p>
          </div>
        </div><!-- /viewGastos -->

        <!-- ===================== RENTABILIDAD ===================== -->
        <div id="viewRentabilidad" hidden>
          <div class="adm-resumen" id="resumenR"></div>

          <div class="adm-bar">
            <input type="text" id="buscarR" class="adm-input adm-search" placeholder="Buscar moto, cliente o matrícula…" />
            <select id="filtroRentabilidadR" class="adm-input adm-mini-sel">
              <option value="">Todas las ventas</option>
              <option value="con_gastos">Con gastos</option>
              <option value="sin_gastos">Sin gastos</option>
            </select>
          </div>

          <div class="adm-list">
            <p class="adm-loading" id="listLoadingR">Cargando…</p>
            <table class="adm-table" id="tablaR" style="display:none">
              <thead><tr><th>Fecha</th><th>Moto</th><th>Cliente</th><th>Venta</th><th>Gastos</th><th>Margen</th><th></th></tr></thead>
              <tbody id="tbodyR"></tbody>
            </table>
            <p class="adm-empty" id="listEmptyR" style="display:none">No hay ventas que coincidan.</p>
          </div>

          <div class="adm-form" id="rentDetalle" style="display:none"></div>
        </div><!-- /viewRentabilidad -->

        <!-- ===================== PROVEEDORES ===================== -->
        <div id="viewProveedores" hidden>
          <div class="adm-bar">
            <button id="btnNuevoProv" class="btn btn-primary">+ Nuevo proveedor</button>
            <input type="text" id="buscarP" class="adm-input adm-search" placeholder="Buscar proveedor o NIF…" />
          </div>

          <!-- FORMULARIO PROVEEDOR -->
          <div class="adm-form" id="formViewP" style="display:none">
            <h2 class="head" id="formTitleP">Nuevo proveedor</h2>
            <div class="adm-grid">
              <input type="hidden" id="p_id" />
              <label>Nombre / Razón social<input type="text" id="p_nombre" class="adm-input" /></label>
              <label>NIF/CIF<input type="text" id="p_nif" class="adm-input" /></label>
              <label class="adm-full">Dirección<input type="text" id="p_direccion" class="adm-input" /></label>
              <label>Email<input type="email" id="p_email" class="adm-input" /></label>
              <label>Teléfono<input type="text" id="p_telefono" class="adm-input" /></label>
              <label>Forma de pago habitual<input type="text" id="p_forma_pago" class="adm-input" /></label>
              <label>Categoría habitual<select id="p_categoria" class="adm-input"></select></label>
              <label class="adm-full">Notas<input type="text" id="p_notas" class="adm-input" /></label>
            </div>
            <div class="adm-form-btns">
              <button id="btnGuardarProv" class="btn btn-primary">Guardar</button>
              <button id="btnCancelarProv" class="btn btn-ghost">Cancelar</button>
            </div>
            <p class="adm-error" id="formErrorP"></p>
          </div>

          <!-- LISTADO PROVEEDORES -->
          <div class="adm-list">
            <p class="adm-loading" id="listLoadingP">Cargando…</p>
            <table class="adm-table adm-table-prov" id="tablaP" style="display:none">
              <thead><tr><th>Nombre</th><th>NIF/CIF</th><th>Email</th><th>Teléfono</th><th>Categoría</th><th></th></tr></thead>
              <tbody id="tbodyP"></tbody>
            </table>
            <p class="adm-empty" id="listEmptyP" style="display:none">Aún no hay proveedores. Crea el primero.</p>
          </div>
        </div><!-- /viewProveedores -->
      </div>
    </div>
  </section>

  <style>
    .adm{min-height:100vh;padding-top:calc(74px + var(--s-7));padding-bottom:var(--s-9)}
    .adm-login{display:flex;align-items:center;justify-content:center;min-height:70vh}
    .adm-card{background:var(--bg-2);border:1px solid var(--line);border-radius:10px;
      padding:var(--s-8);width:min(400px,90vw);display:flex;flex-direction:column;gap:var(--s-4)}
    .adm-card h1{font-size:26px;color:var(--text)}
    .adm-sub{color:var(--text-dim);font-size:var(--fs-small);margin-bottom:var(--s-3)}
    .adm-input{background:var(--bg);border:1px solid var(--line);border-radius:6px;
      padding:11px 13px;color:var(--text);font-size:14px;font-family:inherit;width:100%}
    .adm-input:focus{outline:none;border-color:var(--orange)}
    .adm-btn{cursor:pointer}.btn{cursor:pointer;border:none;font-family:inherit}
    .adm-error{color:#e0563b;font-size:14px;min-height:20px}
    .adm-hint{font-size:12px;min-height:16px;letter-spacing:.01em}
    .adm-hint.ok{color:#4caf7d}
    .adm-hint.bad{color:#e0a13b}

    .adm-top{display:flex;align-items:flex-end;justify-content:space-between;gap:var(--s-4);
      margin-bottom:var(--s-6);flex-wrap:wrap}
    .adm-top h1{font-size:30px;color:var(--text)}

    /* Nota: .adm-stat y .adm-tag se generan por JS (innerHTML), así que sus
       estilos van en el bloque <style is:global> de más abajo. Si se ponen
       aquí (scoped), Astro les añade [data-astro-cid] y no aplican. */
    .adm-resumen{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--s-4);margin-bottom:var(--s-6)}

    .adm-tabs{display:flex;gap:var(--s-1);margin-bottom:var(--s-6);border-bottom:1px solid var(--line)}
    .adm-tab{background:transparent;border:none;border-bottom:2px solid transparent;
      color:var(--text-dim);font-family:'Poppins',sans-serif;font-size:16px;font-weight:600;
      letter-spacing:.02em;padding:10px 20px;cursor:pointer;transition:color .2s var(--ease),border-color .2s var(--ease)}
    .adm-tab:hover{color:var(--text)}
    .adm-tab.is-active{color:var(--orange-bright);border-bottom-color:var(--orange)}
    .adm-upload{cursor:pointer;font-size:var(--fs-small);padding:14px 22px}
    .adm-prov-row{display:flex;gap:var(--s-3);align-items:center}
    .adm-prov-row .adm-input{flex:1}
    .adm-prov-row .adm-mini{white-space:nowrap}
    .adm-lines-box{display:flex;flex-direction:column;gap:10px}
    .adm-lines-head{display:flex;align-items:center;justify-content:space-between;gap:var(--s-3)}
    .adm-lines{display:flex;flex-direction:column;gap:8px}
    .adm-line-row{display:grid;grid-template-columns:minmax(0,1fr) 150px 36px;gap:8px;align-items:center}
    .adm-line-row .adm-ico{width:36px;height:36px;display:flex;align-items:center;justify-content:center}
    .adm-file{padding:8px 10px;cursor:pointer}
    .adm-ocr{background:var(--bg);border:1px solid var(--line);border-radius:8px;
      padding:var(--s-4);margin-bottom:var(--s-5)}
    .adm-ocr-bar{height:6px;background:var(--line);border-radius:99px;overflow:hidden}
    .adm-ocr-bar span{display:block;height:100%;width:0;background:var(--orange);transition:width .3s var(--ease)}
    .adm-ocr-msg{font-size:13px;color:var(--text-dim);margin-top:10px;min-height:18px}

    .adm-bar{display:flex;gap:var(--s-3);flex-wrap:wrap;align-items:center;margin-bottom:var(--s-4)}
    .adm-search{max-width:240px}.adm-mini-sel{max-width:170px;cursor:pointer}
    .adm-export{display:flex;gap:var(--s-3);align-items:center;margin-bottom:var(--s-6);flex-wrap:wrap}
    .adm-export-lbl{font-size:13px;color:var(--text-faint)}

    .adm-form{background:var(--bg-2);border:1px solid var(--line);border-radius:10px;
      padding:var(--s-6);margin-bottom:var(--s-7)}
    .adm-form h2{font-size:22px;color:var(--text);margin-bottom:var(--s-5)}
    .adm-form-cols{display:grid;grid-template-columns:1.3fr 1fr;gap:var(--s-6)}
    .adm-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--s-4)}
    .adm-grid label{display:flex;flex-direction:column;gap:6px;font-size:13px;color:var(--text-dim)}
    .adm-full{grid-column:1/-1}
    .adm-form-btns{display:flex;gap:var(--s-4);margin-top:var(--s-5)}

    .adm-preview{background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:var(--s-5)}
    .adm-preview-lbl{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-faint)}
    .prev-doc{margin-top:var(--s-4);background:#fff;color:#222;border-radius:4px;padding:18px;
      font-size:11px;line-height:1.5;min-height:300px}
    .prev-head{display:flex;justify-content:space-between;align-items:flex-start;
      border-bottom:2px solid var(--orange);padding-bottom:8px;margin-bottom:10px}
    .prev-fact{font-size:16px;font-weight:700;color:#1A150D}
    .prev-num{color:var(--orange);font-weight:600}
    .prev-sec{margin:8px 0}.prev-sec b{color:#1A150D}
    .prev-total{background:var(--orange);color:#fff;padding:6px 10px;border-radius:3px;
      display:flex;justify-content:space-between;font-weight:700;margin-top:8px}
    .prev-legal{font-size:9px;color:#666;margin-top:10px;border-top:1px solid #ddd;padding-top:6px}

    .adm-table{width:100%;border-collapse:collapse}
    .adm-table th{text-align:left;font-size:12px;letter-spacing:.1em;text-transform:uppercase;
      color:var(--text-faint);padding:12px;border-bottom:1px solid var(--line)}
    .adm-table td{padding:12px;border-bottom:1px solid var(--line-soft);color:var(--text-dim);font-size:14px}
    .adm-table tr:hover td{background:rgba(255,255,255,.02)}
    /* .adm-tag movido a <style is:global> (se genera por JS). */

    .adm-mini {
  background: rgba(255,255,255,.04);
  border: 1px solid var(--line);
  color: var(--text-dim);
  font-family: inherit;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .04em;
  padding: 7px 11px;
  border-radius: 4px;
  cursor: pointer;
  transition: all .2s var(--ease);
}

.adm-mini:hover {
  border-color: var(--orange);
  color: var(--orange-bright);
  background: rgba(217,122,40,.08);
  transform: translateY(-1px);
}

.adm-export {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-bottom: var(--s-6);
  flex-wrap: wrap;
}

.adm-export-lbl {
  font-size: 13px;
  color: var(--text-faint);
  margin-right: 2px;
}


    @media(max-width:860px){
      .adm-resumen{grid-template-columns:1fr 1fr}
      .adm-form-cols{grid-template-columns:1fr}
      .adm-preview{display:none}
    }
    @media(max-width:600px){
      .adm-grid{grid-template-columns:1fr}
      .adm-line-row{grid-template-columns:minmax(0,1fr) 112px 36px}
      .adm-table th:nth-child(5),.adm-table td:nth-child(5){display:none}
    }
  </style>

  <style is:global>
  /* Tarjetas de resumen (bubble). Globales porque .adm-resumen se rellena
     por JS con innerHTML y los estilos scoped de Astro no les aplicarían. */
  .adm-stat{
    position:relative;overflow:hidden;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;
    text-align:center;min-height:120px;
    background:radial-gradient(130% 130% at 50% 0%,rgba(217,122,40,.12),rgba(255,255,255,.02) 55%,transparent 100%),var(--bg-2);
    border:1px solid var(--line);border-radius:20px;padding:var(--s-5) var(--s-4);
    transition:transform .3s var(--ease),border-color .3s var(--ease),box-shadow .3s var(--ease);
  }
  .adm-stat::before{
    content:"";position:absolute;top:-45%;left:50%;transform:translateX(-50%);
    width:78%;height:78%;border-radius:50%;pointer-events:none;
    background:radial-gradient(closest-side,rgba(238,138,44,.16),transparent 70%);
  }
  .adm-stat:hover{
    transform:translateY(-3px);border-color:var(--orange);
    box-shadow:0 14px 34px rgba(0,0,0,.35),0 0 0 1px var(--orange-soft);
  }
  .adm-stat-n{
    position:relative;font-size:30px;font-weight:700;line-height:1;
    color:var(--orange-bright);font-family:'Oswald',sans-serif;letter-spacing:.01em;
  }
  .adm-stat-l{
    position:relative;font-size:11px;letter-spacing:.14em;text-transform:uppercase;
    color:var(--text-faint);
  }

  /* Etiquetas de tipo/categoría (también generadas por JS). */
  .adm-tag{font-size:11px;font-weight:600;padding:3px 8px;border-radius:3px}
  .adm-tag.rebu{background:var(--orange-soft);color:var(--orange-bright)}
