    // ============================================================
    //  RENTABILIDAD  (ventas agrupadas con sus gastos asociados)
    // ============================================================
    function gastosDeVenta(ventaId){
      return GASTOS.filter(g=>g.venta_id===ventaId);
    }
    function filaRentabilidad(f){
      const gastos = gastosDeVenta(f.id);
      const totalVenta = Number(f.total||0);
      const totalGastos = gastos.reduce((s,g)=>s+Number(g.total||0),0);
      return {
        venta:f,
        gastos,
        totalVenta,
        totalGastos,
        margen:totalVenta-totalGastos,
      };
    }
    function pintarRentabilidad(){
      if(!$('resumenR')) return;
      RENTABILIDAD = TODAS.map(filaRentabilidad).sort((a,b)=>String(b.venta.fecha||'').localeCompare(String(a.venta.fecha||'')));
      aplicarFiltrosR();
    }
    function aplicarFiltrosR(){
      if(!$('buscarR')) return;
      const q=$('buscarR').value.toLowerCase().trim();
      const filtro=$('filtroRentabilidadR').value;
      VISTAR = RENTABILIDAD.filter(r=>{
        if(filtro==='con_gastos' && !r.gastos.length) return false;
        if(filtro==='sin_gastos' && r.gastos.length) return false;
        const f=r.venta;
        const texto=`${f.numero||''} ${f.cliente_nombre||''} ${f.moto_marca||''} ${f.moto_modelo||''} ${f.moto_matricula||''} ${f.moto_bastidor||''}`.toLowerCase();
        return !q || texto.includes(q);
      });
      pintarResumenR();
      pintarTablaR();
      if(rentSeleccionadaId && !VISTAR.some(r=>r.venta.id===rentSeleccionadaId)){
        rentSeleccionadaId = '';
      }
      const seleccion = rentSeleccionadaId
        ? VISTAR.find(r=>r.venta.id===rentSeleccionadaId)
        : null;
      pintarDetalleRentabilidad(seleccion);
    }
    ['buscarR','filtroRentabilidadR'].forEach(id=>$(id).addEventListener('input',aplicarFiltrosR));

